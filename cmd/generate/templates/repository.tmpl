package [[.Package]]

import (
	"context"
	"errors"

	"[[.ModulePath]]/internal/modules/common"
	"go.mongodb.org/mongo-driver/v2/bson"
	"go.mongodb.org/mongo-driver/v2/mongo"
	"go.mongodb.org/mongo-driver/v2/mongo/options"
)

const (
	collectionName = "[[.DomainPlural]]"
	dbName         common.DBName = common.UNU_ACADEMIC_DB // TODO: change to the target DB
)

type [[.Domain]]Repository interface {
	GetAll(ctx context.Context, filter common.Filter) ([][[.Domain]], error)
	Count(ctx context.Context, filter common.Filter) (int64, error)
	GetByID(ctx context.Context, id string) ([[.Domain]], error)
	Create(ctx context.Context, data *[[.Domain]]) error
	Update(ctx context.Context, data *[[.Domain]]) error
	Delete(ctx context.Context, id string) error
}

type [[.Domain]]RepositoryImpl struct {
	client *mongo.Client
}

func New[[.Domain]]Repository(client *mongo.Client) [[.Domain]]Repository {
	return &[[.Domain]]RepositoryImpl{client: client}
}

func (r *[[.Domain]]RepositoryImpl) col() *mongo.Collection {
	return r.client.Database(string(dbName)).Collection(collectionName)
}

func (r *[[.Domain]]RepositoryImpl) GetAll(ctx context.Context, filter common.Filter) ([][[.Domain]], error) {
	query := bson.M{}
	if filter.Search != "" {
		query["$or"] = bson.A{
			// TODO: add searchable fields, e.g.:
			// bson.M{"name": bson.M{"$regex": filter.Search, "$options": "i"}},
		}
	}

	sortDir := 1
	if filter.SortType == "desc" {
		sortDir = -1
	}
	sortField := "updated_at"
	if filter.SortBy != "" {
		sortField = filter.SortBy
	}

	sortDoc := bson.D{{Key: sortField, Value: sortDir}}
	opts := options.Find().
		SetSort(sortDoc).
		SetSkip(int64((filter.Page - 1) * filter.Limit)).
		SetLimit(int64(filter.Limit))

	cursor, err := r.col().Find(ctx, query, opts)
	if err != nil {
		return [][[.Domain]]{}, err
	}
	defer cursor.Close(ctx)

	var results [][[.Domain]]
	if err := cursor.All(ctx, &results); err != nil {
		return [][[.Domain]]{}, err
	}
	if results == nil {
		return [][[.Domain]]{}, nil
	}
	return results, nil
}

func (r *[[.Domain]]RepositoryImpl) Count(ctx context.Context, filter common.Filter) (int64, error) {
	return r.col().CountDocuments(ctx, bson.M{})
}

func (r *[[.Domain]]RepositoryImpl) GetByID(ctx context.Context, id string) ([[.Domain]], error) {
	oid, err := bson.ObjectIDFromHex(id)
	if err != nil {
		return [[.Domain]]{}, errors.New("invalid id")
	}
	var result [[.Domain]]
	err = r.col().FindOne(ctx, bson.M{"_id": oid}).Decode(&result)
	if errors.Is(err, mongo.ErrNoDocuments) {
		return [[.Domain]]{}, errors.New("[[.DomainSnake]] not found")
	}
	return result, err
}

func (r *[[.Domain]]RepositoryImpl) Create(ctx context.Context, data *[[.Domain]]) error {
	_, err := r.col().InsertOne(ctx, data)
	return err
}

func (r *[[.Domain]]RepositoryImpl) Update(ctx context.Context, data *[[.Domain]]) error {
	_, err := r.col().ReplaceOne(ctx, bson.M{"_id": data.ID}, data)
	return err
}

func (r *[[.Domain]]RepositoryImpl) Delete(ctx context.Context, id string) error {
	oid, err := bson.ObjectIDFromHex(id)
	if err != nil {
		return errors.New("invalid id")
	}
	_, err = r.col().DeleteOne(ctx, bson.M{"_id": oid})
	return err
}
