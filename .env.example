# Server
PORT=3000

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGO_CREDENTIALS=/path/to/cert.pem

# JWT (internal HS256 tokens)
SECRET_KEY=your-jwt-secret-key

# Google / Firebase
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
GOOGLE_SERVICE_ACCOUNT=/path/to/sa.json   # same file, used for RS256 fallback JWT verify

# PubSub
PUBSUB_PROJECT_ID=gcp-project-id

# Redis
REDIS_ENABLE=false
REDIS_URL=redis://localhost:6379

# Auth
STATIC_TOKEN=            # bypass all auth checks when set
AUTH_API_URL=            # base URL for refresh-token validation endpoint
SKIP_PERMISSION=false    # set true to skip Casbin permission checks (dev only)
